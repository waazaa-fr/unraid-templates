  <Registry>waazaafr/sonarr-metadata-localizer:latest</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://discord.gg/p9xkjEw8ts</Support>
